APP_NAME="Certify LMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Docker Compose プロジェクト名 (親ディレクトリが日本語のため明示)
COMPOSE_PROJECT_NAME=certify-lms

# Sail ports (Laravel/Sail 慣習に揃える: web=8000, pma=8080, db=3306, mailpit=8025)
# VITE のみ BookShelf=5173 と衝突するため 5174 に逃がす
APP_PORT=8000
VITE_PORT=5174

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=certify_lms
DB_USERNAME=sail
DB_PASSWORD=password

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# CORS (Sanctum Cookie 認証で別オリジン FE を許可する場合は具体的なオリジンをカンマ区切りで指定)
CORS_ALLOWED_ORIGINS=http://localhost:8000


# === ai-chat (Gemini API) ===
# Gemini API キーは https://aistudio.google.com/apikey から取得(Google アカウント必須、クレカ不要)。
# 無料枠の上限はモデル・時期で変動するため利用前に AI Studio で要確認。既定の gemini-2.5-flash-lite は
# GA(安定版)・低コストで、Flash 系の中でも無料枠が手厚め(2026/05 時点)。
# 受講生個人がそれぞれ API キーを取得して各自の .env に設定する想定。
# 共有 API キー利用は採点環境のみ。
AI_CHAT_ENABLED=true
AI_CHAT_DRIVER=gemini
AI_CHAT_TITLE_GENERATION_ENABLED=true
AI_CHAT_DAILY_MESSAGE_LIMIT=50
AI_CHAT_HISTORY_WINDOW=20
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
