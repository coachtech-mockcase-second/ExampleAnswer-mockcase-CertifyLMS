{
    "preset": "laravel",
    "rules": {
        "declare_strict_types": true,
        "phpdoc_align": {
            "align": "left"
        },
        "phpdoc_indent": true,
        "phpdoc_separation": true,
        "phpdoc_to_comment": false,
        "no_superfluous_phpdoc_tags": false,
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "return_type_declaration": true
    }
}
